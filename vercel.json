{
   "rewrites": [
      {
         "source": "/(.*)",
         "destination": "/index.html"
      }
   ],
   "headers": [
      {
         "source": "/assets/(.*)",
         "headers": [
            {
               "key": "Cache-Control",
               "value": "public, max-age=31536000, immutable"
            }
         ]
      },
      {
         "source": "/(.*\\.webp|.*\\.svg|.*\\.jpg|.*\\.png)",
         "headers": [
            {
               "key": "Cache-Control",
               "value": "public, max-age=604800, stale-while-revalidate=86400"
            }
         ]
      },
      {
         "source": "/index.html",
         "headers": [
            {
               "key": "Cache-Control",
               "value": "public, max-age=0, must-revalidate"
            }
         ]
      }
   ]
}